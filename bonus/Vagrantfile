Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"

  # --- Master Node (GitLab + K3s Server) ---
  config.vm.define "kaisobeS" do |s|
    s.vm.hostname = "kaisobeS"
    s.vm.network "private_network", ip: "192.168.56.110"
    s.vm.provider "virtualbox" do |vb|
      # GitLabを動かすため、最低でも 8GB、余裕を持って 12GB を推奨
      vb.memory = "12288" 
      vb.cpus = 4        # GitLabの内部処理（Sidekiq等）のために4コアは欲しい
      vb.customize ["modifyvm", :id, "--vram", "128"]
    end
    s.vm.provision "shell", path: "scripts/setup_server.sh"
  end

  # --- Worker Node ---
  config.vm.define "kaisobeSW" do |sw|
    sw.vm.hostname = "kaisobeSW"
    sw.vm.network "private_network", ip: "192.168.56.111"
    sw.vm.provider "virtualbox" do |vb|
      # ワーカーはアプリを動かすだけなので 2GB〜4GB でOK
      vb.memory = "4096"
      vb.cpus = 2
    end
    sw.vm.provision "shell", path: "scripts/setup_worker.sh"
  end

  # --- ポートフォワーディングの設定（オプション） ---
  # ホストPCから GitLab UI (80) や Argo CD UI (8080) にアクセスしやすくします
  config.vm.network "forwarded_port", guest: 80, host: 8081, auto_correct: true # GitLab用
  config.vm.network "forwarded_port", guest: 8080, host: 8888, auto_correct: true # Argo CD用
end
